# Customer Success FTE - Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API Key (REQUIRED)
ANTHROPIC_API_KEY=your_api_key_here

# OpenAI API Key (for Phase 2 - optional for Phase 1)
OPENAI_API_KEY=

# Database (for Phase 2 - optional for Phase 1)
DATABASE_URL=

# Kafka (for Phase 2 - optional for Phase 1)
KAFKA_BOOTSTRAP_SERVERS=

# Logging
LOG_LEVEL=INFO
